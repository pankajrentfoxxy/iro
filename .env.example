# IRO - Indian Republic Org
# Copy to .env and fill values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/iro?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES="7d"

# Encryption (AES-256, min 32 chars)
ENCRYPTION_KEY="your-encryption-key-minimum-32-characters-long"

# Webhook (MyOperator / Tollfree)
WEBHOOK_SECRET="optional-webhook-signature-secret"

# WhatsApp Cloud API (Meta Developer Console)
# Webhook URL: https://your-domain/api/webhooks/whatsapp
# Use ngrok for local: ngrok http 4000
WHATSAPP_VERIFY_TOKEN="iro_whatsapp_verify"
# WHATSAPP_ACCESS_TOKEN=your_token_from_meta
# WHATSAPP_PHONE_NUMBER_ID=1025009977364343

# CORS
CORS_ORIGIN="http://localhost:3000"

# Server
PORT=4000

# Dev: First user with this phone becomes NATIONAL_ADMIN
# INIT_ADMIN_PHONE=9876543210

# SMS (MSG91 / Twilio - optional for dev)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Razorpay (optional)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
