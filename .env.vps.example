# IRO VPS Deployment - Copy to .env and fill values
# Required for: docker compose up -d

# Database (IRO uses its own postgres container)
IRO_DB_USER=postgres
IRO_DB_PASSWORD=your_secure_password
IRO_DB_NAME=iro

# If password has special chars (@ # ! etc), set DATABASE_URL with URL-encoded password:
# @ -> %40, # -> %23, ! -> %21
# DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@postgres:5432/iro?schema=public

# Auth (min 32 chars each)
IRO_JWT_SECRET=your-super-secret-jwt-key-min-32-chars
IRO_ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long

# CORS - Your frontend URL (https://iroorg.tech now, https://iro.in later)
IRO_CORS_ORIGIN=https://iroorg.tech
