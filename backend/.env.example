# IRO Backend - Copy to .env and configure

# Database - localhost (dev)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/iro?schema=public"

# For VPS/cloud DB, use:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/iro?schema=public"
# Add &sslmode=require for cloud (Supabase, RDS, etc.)

JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
ENCRYPTION_KEY="your-encryption-key-minimum-32-characters-long"

# Optional
REDIS_URL="redis://localhost:6379"
CORS_ORIGIN="http://localhost:3000"
PORT=4000
