// IRO - Indian Republic Org
// Civic + Political Digital Infrastructure Platform v3.0
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Role {
  MEMBER
  BOOTH_COORDINATOR
  TEHSIL_ADMIN
  DISTRICT_ADMIN
  STATE_ADMIN
  NATIONAL_ADMIN
}

enum ConsentStatus {
  PENDING
  GRANTED
  REVOKED
}

enum CampaignType {
  SMS
  WHATSAPP
  PUSH
  EVENT
}

enum CampaignLogStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum SignupSource {
  MISSED_CALL
  WHATSAPP
  WEB
  APP
  REFERRAL
}

// ============ USERS & AUTH ============

model User {
  id                String        @id @default(uuid())
  phone             String        @unique // AES encrypted at application layer
  name              String?
  age               Int?
  gender            String?
  email             String?
  state             String?
  district          String?
  tehsil            String?
  city              String?
  area              String?       // village
  pincode           String?
  latitude          Float?
  longitude         Float?
  role              Role          @default(MEMBER)
  engagementScore   Int           @default(0)
  referralCode      String        @unique
  referredById      String?
  referredBy        User?         @relation("Referrals", fields: [referredById], references: [id])
  referrals         User[]        @relation("Referrals")
  signupSource      SignupSource?
  ideologyScore     Float         @default(0)
  consentStatus    ConsentStatus @default(PENDING)
  consentTimestamp DateTime?
  passwordHash      String?
  isVerified        Boolean       @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  ideologyPreferences IdeologyPreference[]
  campaignLogs        CampaignLog[]
  analyticsScore      AnalyticsUserScore?
  deviceTokens        DeviceToken[]
  donations           Donation[]
  auditLogs           AuditLog[]    @relation("UserAudit")
  adminActions        AdminActionLog[]
  missedCalls         MissedCall[]
}

// ============ IDEOLOGY & ANALYTICS ============

model IdeologyPreference {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic        String   // economy, youth, employment, governance, nationalism, etc
  interestLevel Int     // 1-5
  source       String   // survey, event, interaction
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([topic])
}

model AnalyticsUserScore {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  engagementScore Int     @default(0)
  influenceScore  Int     @default(0)
  donationScore   Int     @default(0)
  ideologyScore   Float   @default(0)
  lastUpdated    DateTime @updatedAt

  @@index([engagementScore])
  @@index([ideologyScore])
}

// ============ CAMPAIGNS & COMMUNICATION ============

model Campaign {
  id             String       @id @default(uuid())
  title          String
  description    String?
  targetState    String?
  targetDistrict String?
  targetTehsil   String?
  campaignType   CampaignType
  messageContent String?
  createdById    String?
  status         String       @default("draft") // draft, scheduled, running, completed
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  campaignLogs   CampaignLog[]
  bulkSmsQueue   BulkSmsQueue[]
}

model CampaignLog {
  id         String            @id @default(uuid())
  campaignId String
  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone      String?
  status     CampaignLogStatus @default(PENDING)
  response   String?
  timestamp  DateTime          @default(now())

  @@index([campaignId])
  @@index([userId])
}

model BulkSmsQueue {
  id         String    @id @default(uuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String?
  phone      String
  status     String    @default("pending") // pending, sent, failed
  retryCount Int       @default(0)
  scheduledAt DateTime?
  sentAt     DateTime?
  errorMessage String?
  createdAt  DateTime  @default(now())

  @@index([campaignId])
  @@index([status])
}

model PushNotification {
  id             String    @id @default(uuid())
  title          String
  body           String
  targetRole     String?
  targetState    String?
  targetDistrict String?
  scheduledAt    DateTime?
  status         String    @default("draft") // draft, scheduled, sent
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([status])
}

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceType String   // android, ios, web
  token      String
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, token])
  @@index([userId])
}

// ============ DONATIONS ============

model Donation {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("INR")
  razorpayId    String?  @unique
  razorpayOrderId String?
  panNumber     String?  // For future PAN tracking
  status        String   @default("pending") // pending, completed, failed, refunded
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============ WEBHOOKS & CAPTURE ============

model MissedCall {
  id          String   @id @default(uuid())
  phone       String
  userId      String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  source       String  // tollfree, myoperator
  rawPayload   Json?
  processedAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

// ============ AUDIT & COMPLIANCE ============

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation("UserAudit", fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entity     String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AdminActionLog {
  id           String   @id @default(uuid())
  adminId      String
  admin        User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action       String
  targetEntity String?
  targetId     String?
  jurisdiction String?  // state, district, tehsil
  ipAddress    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// ============ MEDIA (Gallery & Videos) ============

model MediaItem {
  id          String   @id @default(uuid())
  type        String   // gallery | video
  title       String
  caption     String?
  imageUrl    String?  // For gallery: image. For video: thumbnail or poster
  videoUrl    String?  // YouTube/Vimeo URL for videos
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([createdAt])
}

// ============ HOMEPAGE STATS OVERRIDE ============

model HomepageStatsOverride {
  id              Int      @id @default(1)
  totalReformers  Int?
  states          Int?
  districts       Int?
  growthPercent   Decimal? @db.Decimal(5, 2)
  useOverride     Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

// ============ LATEST UPDATES (Home Hero) ============

model LatestUpdate {
  id          String   @id @default(uuid())
  title       String
  excerpt     String
  body        String?  // full content for "read more"
  imageUrl    String?
  createdById String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
}
